# Required: API key from https://resend.com (free tier is fine to start)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Required: who receives pilot applications. Comma-separated for multiple recipients.
LEAD_NOTIFY_EMAIL=hello@punchlister.com

# Required for production: a sender on a domain you've verified in Resend.
# For initial testing you can omit this and the function falls back to onboarding@resend.dev,
# but production should use a verified domain (e.g. pilot@punchlister.com).
LEAD_FROM_EMAIL=Punchlister <pilot@punchlister.com>

# Optional. Defaults to the applicant's email so you can hit "reply" directly.
# LEAD_REPLY_TO=
